# Database Configuration
DATABASE_URL="file:./prisma/dev.db"

# AI/LLM API Keys (Optional)
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""

# YouTube OAuth Configuration (Optional)
# Setup guide: see YOUTUBE_OAUTH_SETUP.md
# Get credentials from: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/api/youtube/auth/callback"

# Token Encryption (Required for production)
# Generate with: openssl rand -base64 32
YOUTUBE_ENCRYPTION_KEY="dev-key-change-in-production-12345678"
