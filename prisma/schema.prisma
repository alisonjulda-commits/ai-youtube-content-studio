generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  videoIdeas   VideoIdea[]
  scripts      Script[]
  projects     Project[]
  prompts      Prompt[]
  analytics    Analytics[]
  settings     Settings?
}

model VideoIdea {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?
  category    String
  priority    String   @default("medium")
  difficulty  String   @default("medium")
  status      String   @default("idea")
  tags        String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  scripts Script[]

  @@index([userId])
}

model Script {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  videoIdeaId   String?
  videoIdea     VideoIdea? @relation(fields: [videoIdeaId], references: [id], onDelete: SetNull)
  title         String
  hook          String?
  intro         String?
  body          String?
  examples      String?
  cta           String?
  outro         String?
  tone          String    @default("informative")
  wordCount     Int       @default(0)
  readingTime   Int       @default(0)
  speakingTime  Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  seoData SEOData?

  @@index([userId])
  @@index([videoIdeaId])
}

model SEOData {
  id            String   @id @default(cuid())
  scriptId      String   @unique
  script        Script   @relation(fields: [scriptId], references: [id], onDelete: Cascade)
  title         String
  description   String
  keywords      String
  hashtags      String
  ctrScore      Int      @default(0)
  seoScore      Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Thumbnail {
  id        String   @id @default(cuid())
  videoId   String?
  prompt    String
  design    String?
  colors    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Short {
  id          String   @id @default(cuid())
  videoId     String?
  title       String
  description String?
  content     String
  duration    Int      @default(60)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Project {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?
  status      String   @default("planning")
  dueDate     DateTime?
  checklistItems String? // JSON array
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model Prompt {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  content   String
  category  String
  isFavorite Boolean  @default(false)
  usageCount Int     @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([category])
}

model Settings {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ownerName         String   @default("Julda Marie Alison")
  channelName       String   @default("Julda Marie Alison")
  channelDescription String?
  anthropicApiKey   String?
  openaiApiKey      String?
  brandPrimaryColor String   @default("#6366f1")
  brandSecondaryColor String  @default("#ec4899")
  theme             String   @default("system")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Analytics {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  videoTitle  String
  views       Int      @default(0)
  likes       Int      @default(0)
  comments    Int      @default(0)
  shares      Int      @default(0)
  watchTime   Int      @default(0)
  ctr         Float    @default(0)
  engagementRate Float @default(0)
  date        DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}
